{
    "name": "@lightdash/mcp",
    "version": "0.2098.2",
    "private": true,
    "license": "MIT",
    "description": "MCP for Lightdash REST API（stdio 或独立 Streamable HTTP）",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "bin": {
        "lightdash-mcp": "dist/index.js",
        "lightdash-mcp-http": "dist/http.js"
    },
    "files": [
        "dist/**/*"
    ],
    "scripts": {
        "build": "tsc --project tsconfig.json",
        "typecheck": "tsc --project tsconfig.json --noEmit",
        "start": "node dist/index.js",
        "start:http": "node dist/http.js",
        "lint": "eslint -c ./.eslintrc.js src/**/*.ts",
        "fix-lint": "eslint -c ./.eslintrc.js --fix src/**/*.ts"
    },
    "dependencies": {
        "@lightdash/common": "workspace:*",
        "@modelcontextprotocol/sdk": "^1.17.5",
        "dotenv": "^16.0.2",
        "express": "5.0.1",
        "tslib": "^2.8.1",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@types/express": "^4.17.11",
        "typescript": "5.5.4"
    }
}
